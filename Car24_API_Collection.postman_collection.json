            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@car24.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"9876543210\",\n  \"role\": \"user\"\n}"
